@{
    ViewBag.Title = "İletişim";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section head {
    <link rel="stylesheet" href="~/Content/about.css">
    <link rel="stylesheet" href="~/Content/contact.css">

    <style>
        /* Mesaj kutusu başlangıçta gizli */
        #Message {
            display: none;
            text-align: center;
            padding: 20px;
            color: #000080;
        }

        #msgList {
            list-style-type: none;
            padding: 0;
            font-weight: bold;
            color: #333;
        }
    </style>
}

<div class="about_page">
    @* SOL MENÜ *@
    <section class="about-left">
        <div class="menu-block">
            <span class="menu-title">Kurumsal</span>
            <ul>
                <li><a href="@Url.Action("About", "Home")">Hakkımızda</a></li>
                <li><a href="@Url.Action("Contact", "Home")" >İletişim</a></li>
            </ul>
        </div>
        <div class="menu-block">
            <span class="menu-title">Yardım</span>
            <ul>
                <li><a href="@Url.Action("Index", "QA")">SSS</a></li>
                <li><a href="@Url.Action("Help", "Home")">İptal / İade</a></li>
                <li><a href="@Url.Action("Help", "Home")">Nasıl Bilet Alınır?</a></li>
            </ul>
        </div>
    </section>

    @* ORTA KISIM *@
    <section class="about_center" style="background-color: #19141a">
        <div id="contact" style="width: 1600px; background-color: #765c7a; border-color: #02245e" >
            <h3 class="quickIDTitle" style="color: #000080; text-align: center;">İLETİŞİM FORMU</h3>
            <hr style="border-top: 1px solid #000080;">

            <div id="form">
                <form name="form1" id="form1" onsubmit="return false;">
                    <table id="contactTable">
                        <tr>
                            <td class="formLabel">Ad *</td>
                            <td class="formLabel">Soy Ad *</td>
                        </tr>
                        <tr>
                            <td class="formInput"><input type="text" id="name1" name="nameText" /></td>
                            <td class="formInput"><input type="text" id="lastName1" name="lastNameText" /></td>
                        </tr>
                        <tr>
                            <td class="formLabel">E-Mail *</td>
                            <td class="formLabel">Tel</td>
                        </tr>
                        <tr>
                            <td class="formInput"><input type="text" id="email1" name="emailText" /></td>
                            <td class="formInput"><input type="text" id="tel1" name="telText" /></td>
                        </tr>
                        <tr>
                            <td class="formLabel">Tarih</td>
                            <td class="formLabel">Saat</td>
                        </tr>
                        <tr>
                            <td class="formInput"><input type="date" id="date1" name="dateText" /></td>
                            <td class="formInput"><input type="time" id="time1" name="timeText" /></td>
                        </tr>
                        <tr>
                            <td colspan="2" class="formLabel">Konu *</td>
                        </tr>
                        <tr>
                            <td colspan="2" class="formInputFull"><input type="text" id="subject1" name="subjectText" style="width: 96%;" /></td>
                        </tr>
                        <tr>
                            <td colspan="2" class="formLabel">Mesaj *</td>
                        </tr>
                        <tr>
                            <td colspan="2" class="formInputFull"><input type="text" id="message1" name="messageText" style="height: 100px; width: 96%;" /></td>
                        </tr>
                        <tr>
                            <td colspan="2" style="text-align: center; padding-top: 20px;">
                                <input type="button" id="submitBtn" value="Gönder" onclick="validateForm()" />
                            </td>
                        </tr>
                    </table>
                </form>
            </div>

            <div id="Message">
                <h2 style="color: green;">Teşekkürler</h2>
                <h3>Mesajınız Gönderildi!</h3>
                <br>
                <p>Toplam <span id="msgCount" style="font-weight:bold; color:red;">0</span> mesaj gönderdiniz:</p>
                <ul id="msgList"></ul>
                <br>
                <p>Başka mesaj yollamak için <a href="javascript:void(0);" onclick="resetOutput();" style="color: #000080; font-weight: bold;">buraya tıklayın.</a></p>
            </div>

        </div>
    </section>

    @* SAĞ KISIM *@
    <section class="right">
        <table>
            <tr>
                <td> <img src="~/Content/images/facebook.png" alt="Facebook" class="icon"> </td>
                <td><a href="https://www.facebook.com/" target="_blank">Facebook</a></td>
            </tr>
            <tr>
                <td><img src="~/Content/images/insta.png" alt="Instagram" class="icon"></td>
                <td><a href="https://www.instagram.com/" target="_blank">Instagram</a></td>
            </tr>
            <tr>
                <td><img src="~/Content/images/twiter.png" alt="Twitter" class="icon"></td>
                <td><a href="https://x.com/" target="_blank">Twitter</a></td>
            </tr>
            <tr>
                <td><img src="~/Content/images/youtube.png" alt="YouTube" class="icon"></td>
                <td><a href="https://www.youtube.com/" target="_blank">Youtube</a></td>
            </tr>
        </table>
    </section>
</div>

@section scripts {
    <script src="~/Scripts/contact.js"></script>
}